{
  "expo": {
    "name": "Prointeractive",
    "slug": "prointeractive",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "prointeractive",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.proint",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.proint",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "apiUrl": "https://prointeractive.onrender.com",
      "eas": {
        "projectId": "139f5e42-7f27-45c4-9dab-262a43cb72fa"
      }
    },
    "icon": "./assets/icon.png",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Prointeractive to access your photos so you can add product images to your store."
        }
      ]
    ],
    "owner": "khahtech"
  }
}
